# Required — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Required — https://openrouter.ai/keys — free-tier model works out of the box
OPENROUTER_API_KEY=

# Optional overrides — sensible defaults are used if unset
# LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
# SUMMARIZER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# HOT_BUFFER_SIZE=20
# HOT_BUFFER_TTL_DAYS=7
# SUMMARY_TOPK=3
# SUMMARIZE_EVERY_TURNS=10
